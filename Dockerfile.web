# Dockerfile.web

# ─────────────────────────────────────────────────────────────────────────────
# CHANGELOG
# ─────────────────────────────────────────────────────────────────────────────
#   • Initial — Flutter web build (release), served by Nginx.
#     Split-debug-info and obfuscation for bundle size.
# ─────────────────────────────────────────────────────────────────────────────

# ── Stage 1: Build ────────────────────────────────────────────────────────────
FROM ghcr.io/cirruslabs/flutter:3.27.0 AS builder

WORKDIR /app
COPY pubspec.yaml pubspec.lock ./
RUN flutter pub get

COPY . .
RUN flutter build web --release \
    --split-debug-info=build/debug-info \
    --obfuscate

# ── Stage 2: Serve ────────────────────────────────────────────────────────────
FROM nginx:1.25-alpine

# Copy built web files
COPY --from=builder /app/build/web /usr/share/nginx/html

# Nginx config: SPA fallback (all routes → index.html), gzip, security headers
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

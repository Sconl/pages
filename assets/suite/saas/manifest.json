    "space_value.screen_entry.section_context.proof.headline": "Built for real products",
    "space_value.screen_entry.section_context.proof.body": "From brochure sites to full portals, the same engine runs it all.",

    "space_value.screen_entry.section_connect.offer.headline": "Start building today",
    "space_value.screen_entry.section_connect.offer.body": "Pick a plan. Provision in minutes. Edit live.",
    "space_value.screen_entry.section_connect.offer.cta": "View pricing",

    "space_value.screen_entry.section_connect.path.headline": "How it works",
    "space_value.screen_entry.section_connect.path.step1": "1. Pick a template suite",
    "space_value.screen_entry.section_connect.path.step2": "2. Set your brand",
    "space_value.screen_entry.section_connect.path.step3": "3. Ship. Edit live.",

    "space_value.screen_entry.section_connect.extension.headline": "Built for East Africa",
    "space_value.screen_entry.section_connect.extension.body": "M-Pesa billing, local support, East African market focus."
  }

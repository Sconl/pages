# backend/.env.example
#
# Copy to .env and fill in real values.
# NEVER commit .env — it contains secrets.
# This file documents what's needed; commit only this template.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://qspace:password@localhost:5432/qspace_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be at least 32 characters. Keep secret.
JWT_SECRET=replace_with_64_char_random_string_from_openssl_rand_hex_32

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
RUST_LOG=info

# ── CORS ──────────────────────────────────────────────────────────────────────
# Flutter web build URL during dev. In prod: your actual domain.
ALLOWED_ORIGIN=http://localhost:5000

# ── S3-compatible storage (Cycle 4) ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=af-south-1
S3_BUCKET=qspace-assets
# For DigitalOcean Spaces: https://nyc3.digitaloceanspaces.com
S3_ENDPOINT=https://s3.amazonaws.com
